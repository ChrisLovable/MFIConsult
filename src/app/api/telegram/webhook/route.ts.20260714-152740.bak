import { timingSafeEqual } from "node:crypto";
import { after, NextRequest, NextResponse } from "next/server";
import { getServerEnv } from "@/lib/env";
import { getSupabaseAdmin } from "@/lib/supabase-admin";
import {
  escapeTelegramHtml,
  sendTelegramMessage,
} from "@/lib/telegram";
import { processConsultationSubmission } from "@/lib/consultbill-processing";
import type {
  TelegramAudio,
  TelegramUpdate,
  TelegramVoice,
} from "@/types/telegram";

export const runtime = "nodejs";
export const dynamic = "force-dynamic";
export const maxDuration = 60;

function secureEquals(received: string, expected: string): boolean {
  const receivedBuffer = Buffer.from(received);
  const expectedBuffer = Buffer.from(expected);

  if (receivedBuffer.length !== expectedBuffer.length) {
    return false;
  }

  return timingSafeEqual(receivedBuffer, expectedBuffer);
}

function isCommand(text: string | undefined, command: string): boolean {
  if (!text) {
    return false;
  }

  const firstPart = text.trim().split(/\s+/)[0]?.toLowerCase();
  return firstPart === command || firstPart === `${command}@mficonsult_bot`;
}

function getAudioDetails(
  voice?: TelegramVoice,
  audio?: TelegramAudio,
): {
  fileId: string;
  fileUniqueId: string;
  durationSeconds: number | null;
  mimeType: string | null;
  fileSizeBytes: number | null;
} | null {
  const source = voice ?? audio;

  if (!source) {
    return null;
  }

  return {
    fileId: source.file_id,
    fileUniqueId: source.file_unique_id,
    durationSeconds:
      typeof source.duration === "number" ? source.duration : null,
    mimeType: source.mime_type ?? null,
    fileSizeBytes:
      typeof source.file_size === "number" ? source.file_size : null,
  };
}

export async function GET() {
  return NextResponse.json({
    ok: true,
    route: "ConsultBill Telegram webhook",
  });
}

export async function POST(request: NextRequest) {
  const env = getServerEnv();

  const suppliedSecret =
    request.headers.get("x-telegram-bot-api-secret-token") ?? "";

  if (!secureEquals(suppliedSecret, env.TELEGRAM_WEBHOOK_SECRET)) {
    return NextResponse.json(
      { ok: false, error: "Unauthorized webhook request" },
      { status: 401 },
    );
  }

  let update: TelegramUpdate;

  try {
    update = (await request.json()) as TelegramUpdate;
  } catch {
    return NextResponse.json(
      { ok: false, error: "Invalid JSON" },
      { status: 400 },
    );
  }

  const message = update.message;

  if (!message) {
    return NextResponse.json({ ok: true, ignored: "No message" });
  }

  if (message.chat.type !== "private") {
    return NextResponse.json({
      ok: true,
      ignored: "Only private chats are supported",
    });
  }

  const telegramUser = message.from;
  const chatId = message.chat.id;

  if (!telegramUser) {
    return NextResponse.json({
      ok: true,
      ignored: "Message has no sender",
    });
  }

  const supabase = getSupabaseAdmin();

  const { data: doctor, error: doctorError } = await supabase
    .from("consultbill_doctors")
    .select(`
      id,
      organisation_id,
      full_name,
      is_active,
      email_recipient
    `)
    .eq("telegram_user_id", String(telegramUser.id))
    .maybeSingle();

  if (doctorError) {
    console.error("[ConsultBill] Doctor lookup failed:", doctorError);

    await sendTelegramMessage(
      chatId,
      "The billing service is temporarily unavailable. Please try again shortly.",
    );

    return NextResponse.json(
      { ok: false, error: "Doctor lookup failed" },
      { status: 500 },
    );
  }

  if (isCommand(message.text, "/start")) {
    if (!doctor || !doctor.is_active) {
      await sendTelegramMessage(
        chatId,
        [
          "<b>Welcome to MFI Consult</b>",
          "",
          "Your Telegram account has not yet been linked to an authorised doctor profile.",
          "",
          `Telegram ID: <code>${telegramUser.id}</code>`,
          "",
          "Please send this ID to your MFI onboarding administrator.",
        ].join("\n"),
      );

      return NextResponse.json({ ok: true, linked: false });
    }

    await sendTelegramMessage(
      chatId,
      [
        `<b>Welcome, ${escapeTelegramHtml(doctor.full_name)}</b>`,
        "",
        "Your account is linked and ready.",
        "",
        "Send a voice note containing the consultation billing summary.",
        "You will always review and confirm the billing draft before it is submitted.",
      ].join("\n"),
    );

    return NextResponse.json({ ok: true, linked: true });
  }

  if (isCommand(message.text, "/help")) {
    await sendTelegramMessage(
      chatId,
      [
        "<b>MFI Consult help</b>",
        "",
        "Send one voice note per consultation.",
        "",
        "Include the patient account reference, consultation date and time, consultation type, duration, procedure or tariff details, and any relevant billing modifiers.",
        "",
        "Do not include unnecessary clinical history.",
      ].join("\n"),
    );

    return NextResponse.json({ ok: true });
  }

  const audio = getAudioDetails(message.voice, message.audio);

  if (!audio) {
    await sendTelegramMessage(
      chatId,
      doctor?.is_active
        ? "Please send a consultation voice note, or use /help."
        : "Your Telegram account is not linked. Use /start for onboarding instructions.",
    );

    return NextResponse.json({ ok: true, ignored: "Unsupported message" });
  }

  if (!doctor || !doctor.is_active) {
    await sendTelegramMessage(
      chatId,
      [
        "This Telegram account is not authorised to submit billing instructions.",
        "",
        "Use /start to view your Telegram ID.",
      ].join("\n"),
    );

    return NextResponse.json({ ok: true, authorised: false });
  }

  const { data: submission, error: submissionError } = await supabase
    .from("consultbill_submissions")
    .insert({
      organisation_id: doctor.organisation_id,
      doctor_id: doctor.id,
      telegram_update_id: String(update.update_id),
      telegram_chat_id: String(chatId),
      telegram_message_id: String(message.message_id),
      telegram_file_id: audio.fileId,
      telegram_file_unique_id: audio.fileUniqueId,
      audio_duration_seconds: audio.durationSeconds,
      audio_mime_type: audio.mimeType,
      audio_size_bytes: audio.fileSizeBytes,
      status: "received",
    })
    .select("id, reference, status")
    .single();

  if (submissionError) {
    if (submissionError.code === "23505") {
      const { data: existing } = await supabase
        .from("consultbill_submissions")
        .select("reference, status")
        .eq("telegram_update_id", String(update.update_id))
        .maybeSingle();

      await sendTelegramMessage(
        chatId,
        existing
          ? `This voice note has already been received.\nReference: <code>${escapeTelegramHtml(existing.reference)}</code>`
          : "This voice note has already been received.",
      );

      return NextResponse.json({
        ok: true,
        duplicate: true,
      });
    }

    console.error(
      "[ConsultBill] Submission insert failed:",
      submissionError,
    );

    await sendTelegramMessage(
      chatId,
      "The voice note could not be registered. Please try again.",
    );

    return NextResponse.json(
      { ok: false, error: "Submission insert failed" },
      { status: 500 },
    );
  }

  await sendTelegramMessage(
    chatId,
    [
      "<b>Voice note received</b>",
      "",
      `Reference: <code>${escapeTelegramHtml(submission.reference)}</code>`,
      "",
      "The consultation will now be transcribed and prepared as a billing draft.",
    ].join("\n"),
  );

  after(async () => {
    await processConsultationSubmission(submission.id);
  });

  return NextResponse.json({
    ok: true,
    submissionId: submission.id,
    reference: submission.reference,
  });
}

