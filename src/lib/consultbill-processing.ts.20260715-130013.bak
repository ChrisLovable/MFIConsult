import type { BillingExtraction } from "@/lib/billing-extraction";
import { extractBillingDetails } from "@/lib/billing-extraction";
import { getServerEnv } from "@/lib/env";
import { getSupabaseAdmin } from "@/lib/supabase-admin";
import {
  escapeTelegramHtml,
  sendTelegramMessage,
  telegramApi,
} from "@/lib/telegram";
import { transcribeConsultationAudio } from "@/lib/transcription";

interface TelegramFile {
  file_id: string;
  file_unique_id: string;
  file_size?: number;
  file_path?: string;
}

interface SubmissionRecord {
  id: string;
  reference: string;
  doctor_id: string;
  telegram_chat_id: string | number;
  telegram_file_id: string;
  audio_mime_type: string | null;
  status: string;
}

interface DoctorRecord {
  id: string;
  full_name: string;
  billing_profile: Record<string, unknown> | null;
}

function safeMessage(error: unknown): string {
  if (error instanceof Error) {
    return error.message.slice(0, 1000);
  }

  return String(error).slice(0, 1000);
}

async function downloadTelegramAudio(
  fileId: string,
): Promise<{
  audio: Buffer;
  mimeType: string;
}> {
  const env = getServerEnv();

  const file = await telegramApi<TelegramFile>("getFile", {
    file_id: fileId,
  });

  if (!file.file_path) {
    throw new Error("Telegram returned no downloadable file path.");
  }

  const response = await fetch(
    `https://api.telegram.org/file/bot${env.TELEGRAM_BOT_TOKEN}/${file.file_path}`,
    {
      cache: "no-store",
      signal: AbortSignal.timeout(20000),
    },
  );

  if (!response.ok) {
    throw new Error(
      `Telegram audio download failed: ${response.status}`,
    );
  }

  const audio = Buffer.from(await response.arrayBuffer());
  const mimeType =
    response.headers.get("content-type") || "audio/ogg";

  return {
    audio,
    mimeType,
  };
}

function displayValue(
  value: string | number | null,
): string {
  if (value === null || value === "") {
    return "Not provided";
  }

  return escapeTelegramHtml(value);
}

function displayCodes(
  codes: BillingExtraction["icd10_codes"],
): string {
  if (!codes.length) {
    return "None provided";
  }

  return codes
    .map((item) => {
      const source =
        item.source === "doctor_stated"
          ? "doctor stated"
          : "AI suggestion";

      return `${escapeTelegramHtml(item.code)} â€” ${escapeTelegramHtml(item.description)} (${source})`;
    })
    .join("\n");
}

function formatBillingDraft(
  reference: string,
  extraction: BillingExtraction,
): string {
  const lines = [
    "<b>BILLING DRAFT</b>",
    `Reference: <code>${escapeTelegramHtml(reference)}</code>`,
    "",
    `<b>Patient reference:</b> ${displayValue(extraction.patient_reference)}`,
    `<b>Patient name:</b> ${displayValue(extraction.patient_name)}`,
    `<b>Date:</b> ${displayValue(extraction.consultation_date)}`,
    `<b>Time:</b> ${displayValue(extraction.consultation_time)}`,
    `<b>Consultation:</b> ${displayValue(extraction.consultation_type)}`,
    `<b>Duration:</b> ${
      extraction.duration_minutes === null
        ? "Not provided"
        : `${escapeTelegramHtml(extraction.duration_minutes)} minutes`
    }`,
    `<b>Place:</b> ${displayValue(extraction.place_of_service)}`,
    `<b>Diagnosis summary:</b> ${displayValue(extraction.diagnosis_summary)}`,
    "",
    "<b>ICD-10:</b>",
    displayCodes(extraction.icd10_codes),
    "",
    "<b>Tariffs:</b>",
    displayCodes(extraction.tariff_codes),
  ];

  if (extraction.procedures.length) {
    lines.push(
      "",
      "<b>Procedures:</b>",
      extraction.procedures
        .map((value) => `â€¢ ${escapeTelegramHtml(value)}`)
        .join("\n"),
    );
  }

  if (extraction.medical_aid) {
    lines.push(
      "",
      `<b>Medical aid:</b> ${escapeTelegramHtml(extraction.medical_aid)}`,
    );
  }

  if (extraction.authorisation_number) {
    lines.push(
      `<b>Authorisation:</b> ${escapeTelegramHtml(extraction.authorisation_number)}`,
    );
  }

  if (extraction.missing_fields.length) {
    lines.push(
      "",
      "<b>Missing information:</b>",
      extraction.missing_fields
        .map((value) => `â€¢ ${escapeTelegramHtml(value)}`)
        .join("\n"),
    );
  }

  if (extraction.warnings.length) {
    lines.push(
      "",
      "<b>Warnings:</b>",
      extraction.warnings
        .map((value) => `â€¢ ${escapeTelegramHtml(value)}`)
        .join("\n"),
    );
  }

  lines.push(
    "",
    `<b>Extraction confidence:</b> ${Math.round(extraction.confidence * 100)}%`,
    "",
    "Review this draft. Type CONFIRM, or send a short voice note saying confirm. Type or say CANCEL to discard it.",
  );

  return lines.join("\n").slice(0, 4000);
}

function getTranscriptionKeyterms(
  billingProfile: Record<string, unknown>,
): string[] {
  const configured = Array.isArray(
    billingProfile.transcription_keyterms,
  )
    ? billingProfile.transcription_keyterms.filter(
        (value): value is string =>
          typeof value === "string" && value.trim().length > 0,
      )
    : [];

  return Array.from(
    new Set([
      "ICD-10",
      "tariff code",
      "medical aid",
      "authorisation number",
      "I10",
      "0191",
      "Discovery",
      ...configured,
    ]),
  );
}
export async function processConsultationSubmission(
  submissionId: string,
): Promise<void> {
  const supabase = getSupabaseAdmin();

  let chatId: number | null = null;
  let reference = submissionId;

  try {
    const { data: claimed, error: claimError } = await supabase
      .from("consultbill_submissions")
      .update({
        status: "transcribing",
        error_message: null,
      })
      .eq("id", submissionId)
      .eq("status", "received")
      .select(`
        id,
        reference,
        doctor_id,
        telegram_chat_id,
        telegram_file_id,
        audio_mime_type,
        status
      `)
      .maybeSingle();

    if (claimError) {
      throw claimError;
    }

    if (!claimed) {
      return;
    }

    const submission = claimed as SubmissionRecord;
    reference = submission.reference;
    chatId = Number(submission.telegram_chat_id);

    const { data: doctorData, error: doctorError } =
      await supabase
        .from("consultbill_doctors")
        .select("id, full_name, billing_profile")
        .eq("id", submission.doctor_id)
        .single();

    if (doctorError) {
      throw doctorError;
    }

    const doctor = doctorData as DoctorRecord;

    const downloaded = await downloadTelegramAudio(
      submission.telegram_file_id,
    );

    const transcript = await transcribeConsultationAudio(
      downloaded.audio,
      submission.audio_mime_type || downloaded.mimeType,
      getTranscriptionKeyterms(doctor.billing_profile ?? {}),
    );

    const { error: transcriptUpdateError } = await supabase
      .from("consultbill_submissions")
      .update({
        transcript,
        status: "extracting",
      })
      .eq("id", submission.id);

    if (transcriptUpdateError) {
      throw transcriptUpdateError;
    }

    const extraction = await extractBillingDetails(
      transcript,
      doctor.billing_profile ?? {},
    );

    const { error: extractionUpdateError } = await supabase
      .from("consultbill_submissions")
      .update({
        extraction,
        status: "needs_confirmation",
      })
      .eq("id", submission.id);

    if (extractionUpdateError) {
      throw extractionUpdateError;
    }

    await sendTelegramMessage(
      chatId,
      formatBillingDraft(reference, extraction),
    );
  } catch (error) {
    const message = safeMessage(error);

    console.error(
      `[ConsultBill] Processing failed for ${reference}:`,
      message,
    );

    await supabase
      .from("consultbill_submissions")
      .update({
        status: "failed",
        error_message: message,
      })
      .eq("id", submissionId);

    if (chatId !== null) {
      await sendTelegramMessage(
        chatId,
        [
          "<b>Consultation processing failed</b>",
          `Reference: <code>${escapeTelegramHtml(reference)}</code>`,
          "",
          "The voice note was safely registered, but transcription or extraction could not be completed.",
          "Please try again after the configuration has been checked.",
        ].join("\n"),
      );
    }
  }
}



